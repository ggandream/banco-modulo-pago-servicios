graph TB
    subgraph Frontend["Frontend (React + Mantine + Vite)"]
        UI[UI Components]
        AuthStore[Auth Store - Zustand]
        Pages[Pages & Routes]
        UI --> AuthStore
        UI --> Pages
    end

    subgraph Backend["Backend (NestJS)"]
        AuthModule[AuthModule<br/>POST /api/auth/login]
        UsersModule[UsersModule<br/>CRUD /api/users]
