datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// ============================================================================
// ROL
// ============================================================================
model Rol {
  id               Int       @id @default(autoincrement())
  nombre           String    @unique @db.VarChar(50)
  estado           Boolean   @default(true)
  fechaCreacion    DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime? @map("fecha_actualizacion")

  usuarios Usuario[]

  @@map("rol")
}

// ============================================================================
// USUARIO
// ============================================================================
model Usuario {
  id               Int       @id @default(autoincrement())
  nombreCompleto   String    @map("nombre_completo") @db.VarChar(150)
  nombreUsuario    String    @unique @map("nombre_usuario") @db.VarChar(50)
  correo           String    @unique @db.VarChar(150)
  passwordHash     String    @map("password_hash")
  rolId            Int       @map("rol_id")
  estado           Boolean   @default(true)
  fechaCreacion    DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime? @map("fecha_actualizacion")

  rol              Rol       @relation(fields: [rolId], references: [id])
  cuentasBancarias CuentaBancaria[]
  pagos            Pago[]
  historialPagos   HistorialPagos[]

  @@map("usuario")
}

// ============================================================================
// CUENTA BANCARIA
// ============================================================================
model CuentaBancaria {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @map("usuario_id")
  numeroCuenta  String   @unique @map("numero_cuenta") @db.VarChar(20)
  saldo         Decimal  @db.Decimal(12, 2)
  tipoCuenta    String   @map("tipo_cuenta") @db.VarChar(50)
  estado        Boolean  @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  pagos   Pago[]

  @@map("cuenta_bancaria")
}

// ============================================================================
// TIPO DE SERVICIO
// ============================================================================
model TipoServicio {
  id               Int       @id @default(autoincrement())
  nombre           String    @unique @db.VarChar(50)
  estado           Boolean   @default(true)
  fechaCreacion    DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime? @map("fecha_actualizacion")

  empresas EmpresaServicio[]
  historialPagos HistorialPagos[]

  @@map("tipo_servicio")
}

// ============================================================================
// EMPRESA DE SERVICIO
// ============================================================================
model EmpresaServicio {
  id               Int       @id @default(autoincrement())
  nombre           String    @db.VarChar(150)
  tipoServicioId   Int       @map("tipo_servicio_id")
  tarifaMensual    Decimal   @map("tarifa_mensual") @db.Decimal(10, 2)
  estado           Boolean   @default(true)
  fechaCreacion    DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime? @map("fecha_actualizacion")

  tipoServicio     TipoServicio @relation(fields: [tipoServicioId], references: [id])
  contadores       ContadorServicio[]
  tarifas          TarifasServicio[]
  pagos            Pago[]
  historialPagos   HistorialPagos[]

  @@map("empresa_servicio")
}

// ============================================================================
// CONTADOR DE SERVICIO
// ============================================================================
model ContadorServicio {
  id              Int      @id @default(autoincrement())
  numeroContador  String   @unique @map("numero_contador") @db.VarChar(50)
  empresaId       Int      @map("empresa_id")
  alias           String?  @db.VarChar(100)
  estado          Boolean  @default(true)
  fechaCreacion   DateTime @default(now()) @map("fecha_creacion")

  empresa EmpresaServicio @relation(fields: [empresaId], references: [id])
  historialPagos HistorialPagos[]

  @@map("contador_servicio")
}

// ============================================================================
// PAGO
// ============================================================================
model Pago {
  id                  Int      @id @default(autoincrement())
  usuarioId           Int      @map("usuario_id")
  empresaId           Int      @map("empresa_id")
  numeroContador      String   @map("numero_contador") @db.VarChar(50)
  cuentaBancariaId    Int      @map("cuenta_bancaria_id")
  montoPagado         Decimal  @map("monto_pagado") @db.Decimal(10, 2)
  mesCorrespondiente  Int      @map("mes_correspondiente")
  anioCorrespondiente Int      @map("anio_correspondiente")
  estado              String   @default("aprobado") @db.VarChar(20)
  fechaPago           DateTime @default(now()) @map("fecha_pago")
  fechaCreacion       DateTime @default(now()) @map("fecha_creacion")

  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  empresa        EmpresaServicio @relation(fields: [empresaId], references: [id])
  cuentaBancaria CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id])
  comprobante    Comprobante?
  historialPagos HistorialPagos[]

  @@unique([numeroContador, empresaId, mesCorrespondiente, anioCorrespondiente])
  @@map("pago")
}

// ============================================================================
// HISTORIAL DE PAGOS
// ============================================================================
model HistorialPagos {
  id             Int      @id @default(autoincrement())
  pagoId         Int      @map("pago_id")
  empresaId      Int?     @map("empresa_id")
  usuarioId      Int?     @map("usuario_id")
  contadorId     Int?     @map("contador_id")
  tipoServicioId Int?     @map("tipo_servicio_id")
  fechaEvento    DateTime @default(now()) @map("fecha_evento")

  pago         Pago              @relation(fields: [pagoId], references: [id])
  empresa      EmpresaServicio?  @relation(fields: [empresaId], references: [id])
  usuario      Usuario?          @relation(fields: [usuarioId], references: [id])
  contador     ContadorServicio? @relation(fields: [contadorId], references: [id])
  tipoServicio TipoServicio?     @relation(fields: [tipoServicioId], references: [id])

  @@map("historial_pagos")
}

// ============================================================================
// TARIFAS DE SERVICIO
// ============================================================================
model TarifasServicio {
  id                   Int       @id @default(autoincrement())
  empresaId            Int       @map("empresa_id")
  montoMensual         Decimal   @map("monto_mensual") @db.Decimal(10, 2)
  fechaInicioVigencia  DateTime  @map("fecha_inicio_vigencia") @db.Date
  fechaFinVigencia     DateTime? @map("fecha_fin_vigencia") @db.Date
  estado               Boolean   @default(true)

  empresa EmpresaServicio @relation(fields: [empresaId], references: [id])

  @@map("tarifas_servicio")
}

// ============================================================================
// COMPROBANTE
// ============================================================================
model Comprobante {
  id                 Int      @id @default(autoincrement())
  pagoId             Int      @unique @map("pago_id")
  numeroComprobante  String   @unique @map("numero_comprobante") @db.VarChar(50)
  fechaEmision       DateTime @default(now()) @map("fecha_emision")
  monto              Decimal  @db.Decimal(10, 2)
  empresa            String   @db.VarChar(150)
  numeroContador     String   @map("numero_contador") @db.VarChar(50)

  pago Pago @relation(fields: [pagoId], references: [id])

  @@map("comprobante")
}
