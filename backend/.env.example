# =============================================================================
# Backend Environment Variables
# =============================================================================

# Database connection (for local development without Docker Compose)
DATABASE_URL="postgresql://root:root@localhost:5432/mydb?schema=public"

# JWT secret for authentication
JWT_SECRET="banco_modulo_secret_2026"

# Server port (default: 3000)
PORT=3000

# =============================================================================
# Docker Compose specific (used by entrypoint.sh)
# =============================================================================

# PostgreSQL connection details (used for health check in entrypoint)
DB_HOST=postgres
DB_PORT=5432

# Set to "true" to run seed on container startup (first time only)
RUN_SEED=false

# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=mydb

# Mi .env actual:
DATABASE_URL="postgresql://root:root@localhost:5432/mydb?schema=public"
JWT_SECRET="banco_modulo_secret_2026"
PORT=3000
DB_HOST=postgres
DB_PORT=5432
RUN_SEED=false
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=mydb